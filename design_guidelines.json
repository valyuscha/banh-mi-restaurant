  "testing_requirements": {
    "attributes": "All interactive and key informational elements MUST include a data-testid attribute in kebab-case."
  },
  "instructions_to_main_agent": [
    "Keep ALL existing structure, layout, and Framer Motion animations strictly intact.",
    "Do not alter the logical components (e.g. the EN/PL/DE multilingual switcher, form submission handling). Only update styling, text typography, colors, and media replacements.",
    "Perform a direct replacement of hardcoded hex values across all `.js` component files using the exact hex-to-hex mappings provided in the color_palette.",
    "Update standard HTML font classes from Serif (Cormorant) to Chivo, and Sans (Outfit) to Manrope. Ensure you update font imports/classes accordingly.",
    "Ensure hover, active, and focus states retain sufficient contrast, relying entirely on the new deep red / warm beige / dark green / black color scheme.",
    "Add 'data-testid' attributes to all interactive elements for testability."
  ]
}