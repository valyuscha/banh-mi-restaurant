{
  "theme_and_archetype": {
    "domain": "Restaurant / Vietnamese Street Food",
    "theme": "Light",
    "archetype": "1 (Organic & Earthy / Street Food Adaptation)"
  },
  "color_palette": {
    "background": {
      "hex": "#F9F3EA",
      "hsl": "40 50% 95%",
      "description": "Warm beige for primary backgrounds",
      "replaces_old_hex": "#FDFBF7"
    },
    "primary": {
      "hex": "#A11D1C",
      "hsl": "0 70% 37%",
      "description": "Deep red for main accents, buttons, highlights",
      "replaces_old_hex": "#C86F54"
    },
    "secondary": {
      "hex": "#1A3B26",
      "hsl": "142 39% 16%",
      "description": "Dark green for secondary buttons, borders, badges, and footer",
      "replaces_old_hex": "#2F6042"
    },
    "text_main": {
      "hex": "#111111",
      "hsl": "0 0% 7%",
      "description": "Black accents for typography and headings",
      "replaces_old_hex": "#2C1E16"
    }
  },
  "typography": {
    "headings": {
      "font_family": "Chivo, sans-serif",
      "weights": ["700", "800", "900"],
      "description": "Bold, punchy sans-serif to capture the vibrant, energetic vibe of Vietnamese street food signage. Replaces Cormorant Garamond."
    },
    "body": {
      "font_family": "Manrope, sans-serif",
      "weights": ["400", "500", "600"],
      "description": "Clean, highly legible sans-serif for optimal readability. Replaces Outfit."
    }
  },
